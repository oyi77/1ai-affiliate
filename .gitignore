# Configuration files
1ai-config.php
1ai-config*.php
!1ai-config-sample.php
1ai-config copy.php
phpstan.neon

# PSR-4 autoload compatibility symlinks (created by install.sh / test.sh).
# These map legacy names to current directories so stale vendor/ works.
/1ai-config
/1ai-interfaces
/tracking1ai

# Environment / secrets
.env
.env.*

# Docker
docker-compose.yaml
docker-compose.staging.yml
docker-compose.*.yml

# Dependencies
/node_modules/
/vendor/
/server/node_modules/
composer.lock
/server/package-lock.json

# Build and cache files
*.cache
*.patch
build/debug/
build/logs/
build/staging-config.php
/build/

# Development and documentation
/docs/
phpstan-errors.txt
task-plan-*
multi-touch-qa-runbook.md

