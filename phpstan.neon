includes:
    - phpstan-baseline.neon
parameters:
    # 1ai-Affiliate PHPStan config — level 5 with a baseline of pre-existing issues.
    # New code MUST be clean (no baseline additions allowed for new files).
    level: 5
    paths:
        - config
        - api
        - interfaces
    excludePaths:
        - config/install.php
        - config/upgrade.php
        - config/setup-config.php
        - config/temp
        - config/data
        - config/geo
        - config/functions-upgrade.php
        - config/class-dataengine.php
        - config/class-dataengine-slim.php
        - config/class-filterengine.php
        - config/ReportBasicForm.class.php
        - config/ReportSummaryForm.class.php
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    bootstrapFiles:
        - phpstan-bootstrap.php
services:
    -
        class: OneAIAffiliate\PHPStan\Rules\ForbidDirectMysqliStmtCallRule
        tags:
            - phpstan.rules.rule
    -
        class: OneAIAffiliate\PHPStan\Rules\ForbidDirectPasswordHashRule
        tags:
            - phpstan.rules.rule
    -
        class: OneAIAffiliate\PHPStan\Rules\ForbidSilentJsonDecodeRule
        tags:
            - phpstan.rules.rule
