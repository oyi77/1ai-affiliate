                                            <button type=button data-style=emoji class=option-btn-karikatur><i
                                                    class="fas fa-smile mr-2"></i> <span>Emoji Style</span></button>
                                            <button type=button data-style=retro class=option-btn-karikatur><i
                                                    class="fas fa-tv mr-2"></i> <span>Retro/Vintage</span></button>
                                            <button type=button data-style=noir class=option-btn-karikatur><i
                                                    class="fas fa-moon mr-2"></i> <span>Film Noir</span></button>
                                            <button type=button data-style=pastel class=option-btn-karikatur><i
                                                    class="fas fa-cloud mr-2"></i> <span>Pastel Soft</span></button>
                                            <button type=button data-style=monochrome class=option-btn-karikatur><i
                                                    class="fas fa-adjust mr-2"></i> <span>Monochrome</span></button>
                                            <button type=button data-style=fantasy class=option-btn-karikatur><i
                                                    class="fas fa-hat-wizard mr-2"></i> <span>Fantasy
                                                    Art</span></button> <button type=button data-style=gothic
                                                class=option-btn-karikatur><i class="fas fa-skull mr-2"></i>
                                                <span>Gothic Dark</span></button> <button type=button data-style=kawaii
                                                class=option-btn-karikatur><i class="fas fa-heart mr-2"></i>
                                                <span>Kawaii Japan</span></button> <button type=button
                                                data-style=realistic class=option-btn-karikatur><i
                                                    class="fas fa-camera mr-2"></i> <span>Realistic</span></button>
                                            <button type=button data-style=portrait class=option-btn-karikatur><i
                                                    class="fas fa-user-circle mr-2"></i> <span>Portrait
                                                    Art</span></button> <button type=button data-style=editorial
                                                class=option-btn-karikatur><i class="fas fa-newspaper mr-2"></i>
                                                <span>Editorial</span></button> <button type=button data-style=vogue
                                                class=option-btn-karikatur><i class="fas fa-user-tie mr-2"></i>
                                                <span>Vogue Fashion</span></button> <button type=button
                                                data-style=wayang class=option-btn-karikatur><i
                                                    class="fas fa-theater-masks mr-2"></i> <span>Wayang
                                                    Style</span></button> <button type=button data-style=batik
                                                class=option-btn-karikatur><i class="fas fa-leaf mr-2"></i> <span>Batik
                                                    Pattern</span></button> <button type=button data-style=flatcartoon
                                                class=option-btn-karikatur><i class="fas fa-star mr-2"></i> <span>Flat
                                                    Cartoon</span></button> <button type=button data-style=custom
                                                class=option-btn-karikatur><i class="fas fa-pen-fancy mr-2"></i>
                                                <span>Custom</span></button>
                                        </div>
                                        <div id=karikatur-custom-style-container class="mt-3 hidden"><input type=text
                                                id=karikatur-custom-style
                                                class="w-full px-4 py-2 border-2 border-orange-300 rounded-lg focus:border-orange-500 focus:outline-none"
