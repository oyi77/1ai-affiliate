                                                data-value=detailed class="option-btn-analyzer selected"><i
                                                    class="fas fa-list-ul"></i> <span
                                                    class=text-sm>Detailed</span></button> <button type=button
                                                data-value=expert class=option-btn-analyzer><i
                                                    class="fas fa-microscope"></i> <span
                                                    class=text-sm>Expert</span></button></div>
