                                            <button type=button data-style=instagram class=option-btn-karikatur><i
                                                    class="fab fa-instagram mr-2"></i> <span>Instagram</span></button>
                                            <button type=button data-style=tiktok class=option-btn-karikatur><i
                                                    class="fab fa-tiktok mr-2"></i> <span>TikTok Viral</span></button>
                                            <button type=button data-style=sticker class=option-btn-karikatur><i
