                                                class="option-btn-packaging selected"><i class="fas fa-circle"></i>
                                                <span class=text-sm>Minimalist</span></button> <button type=button
                                                data-value=luxury class=option-btn-packaging><i class="fas fa-gem"></i>
                                                <span class=text-sm>Luxury</span></button> <button type=button
                                                data-value=eco class=option-btn-packaging><i class="fas fa-leaf"></i>
                                                <span class=text-sm>Eco-Friendly</span></button> <button type=button
                                                data-value=modern class=option-btn-packaging><i
                                                    class="fas fa-shapes"></i> <span
                                                    class=text-sm>Modern</span></button> <button type=button
                                                data-value=vintage class=option-btn-packaging><i
                                                    class="fas fa-clock"></i> <span
                                                    class=text-sm>Vintage</span></button> <button type=button
                                                data-value=playful class=option-btn-packaging><i
                                                    class="fas fa-smile"></i> <span
                                                    class=text-sm>Playful</span></button></div>
                                    </div>
                                    <div class=mb-6>
