                                            class="fas fa-graduation-cap text-white text-3xl"></i></div>
                                    <div class="flex flex-col items-start">
                                        <h1 class="text-4xl md:text-5xl font-bold text-transparent bg-clip-text"
                                            style="background:linear-gradient(135deg,#a855f7 0,#ec4899 100%)">Foto
