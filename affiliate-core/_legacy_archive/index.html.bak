                                        class="flex items-center justify-center"><svg xmlns=http://www.w3.org/2000/svg
                                            class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill=none stroke=currentColor
                                            stroke-width=2 stroke-linecap=round stroke-linejoin=round>
                                            <path d="m3 16 2 2 4-4" />
                                            <path d="m3 12 2 2 4-4" />
                                            <path d="M10 6h11" />
                                            <path d="M10 12h11" />
                                            <path d="M10 18h11" />
                                        </svg> Pilih 6 Pose</span></button></div>
