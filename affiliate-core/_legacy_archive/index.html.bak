                                            style="border-color:#92400e;background:linear-gradient(135deg,#fef3c7 0,#fde68a 100%)">
                                            <div class="flex flex-col items-center gap-2"><i
                                                    class="fas fa-cloud-upload-alt text-4xl" style=color:#92400e></i>
                                                <span class=font-semibold style=color:#78350f>Klik untuk upload</span>
                                                <span class="text-xs text-gray-500">PNG, JPG, WEBP, HEIC</span>
                                            </div>
                                            <input type=file id=packaging-product-upload class=hidden
                                                accept="image/png, image/jpeg, image/webp, image/heic, .heic">
                                        </label>
                                        <div id=packaging-product-preview-container class="mt-3 hidden"><img
                                                id=packaging-product-preview src="" alt=Preview
                                                class="w-full rounded-lg shadow-lg max-h-64 object-cover border-2"
                                                style=border-color:#92400e> <button id=packaging-remove-product
                                                class="mt-2 w-full bg-red-600 hover:bg-red-700 text-white text-sm py-2 px-3 rounded-lg transition-all"><i
                                                    class="fas fa-times mr-1"></i> Hapus Foto</button></div>
                                    </div>
                                    <div class=mb-6>
                                        <div class="flex items-center gap-3 mb-4">
                                            <div class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white shadow-md"
                                                style="background:linear-gradient(135deg,#92400e 0,#78350f 100%)">2
                                            </div>
                                            <h3 class="text-lg font-bold text-gray-800">Jenis Kemasan</h3>
                                        </div>
                                        <div id=packaging-type-options class="grid grid-cols-2 gap-3"><button
                                                type=button data-value=box class="option-btn-packaging selected"><i
                                                    class="fas fa-box"></i> <span
                                                    class=text-sm>Box/Kardus</span></button> <button type=button
                                                data-value=pouch class=option-btn-packaging><i
                                                    class="fas fa-shopping-bag"></i> <span
                                                    class=text-sm>Pouch/Plastik</span></button> <button type=button
                                                data-value=bottle class=option-btn-packaging><i
                                                    class="fas fa-wine-bottle"></i> <span
                                                    class=text-sm>Bottle</span></button> <button type=button
                                                data-value=can class=option-btn-packaging><i
                                                    class="fas fa-prescription-bottle"></i> <span
                                                    class=text-sm>Can/Kaleng</span></button> <button type=button
                                                data-value=paperbag class=option-btn-packaging><i
                                                    class="fas fa-bag-shopping"></i> <span class=text-sm>Paper
                                                    Bag</span></button> <button type=button data-value=tube
                                                class=option-btn-packaging><i class="fas fa-fill-drip"></i> <span
                                                    class=text-sm>Tube</span></button></div>
                                    </div>
                                    <div class=mb-6>
