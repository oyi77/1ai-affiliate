                                                <h2 class="text-xl font-semibold text-gray-800">Aspect Ratio</h2>
                                            </div>
                                            <div id=review-ratio-selection class="grid grid-cols-2 gap-3"><button
                                                    type=button
                                                    class="ratio-btn-review flex items-center gap-2 p-3 border-2 border-gray-200 rounded-xl hover:border-indigo-400 transition-all active:scale-95"
                                                    data-ratio=1:1><svg xmlns=http://www.w3.org/2000/svg width=20
                                                        height=20 viewBox="0 0 24 24" fill=none stroke=currentColor
                                                        stroke-width=2 stroke-linecap=round stroke-linejoin=round>
                                                        <rect width=16 height=16 x=4 y=4 rx=2></rect>
                                                    </svg> <span class="font-medium text-sm">1:1 Square</span></button>
                                                <button type=button
