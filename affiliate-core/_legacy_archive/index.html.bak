                                            <button type=button data-style=vector class=option-btn-karikatur><i
                                                    class="fas fa-bezier-curve mr-2"></i> <span>Vector
                                                    Art</span></button> <button type=button data-style=minimalist
                                                class=option-btn-karikatur><i class="fas fa-circle mr-2"></i>
                                                <span>Minimalist</span></button> <button type=button
                                                data-style=geometric class=option-btn-karikatur><i
                                                    class="fas fa-shapes mr-2"></i> <span>Geometric</span></button>
                                            <button type=button data-style=neon class=option-btn-karikatur><i
                                                    class="fas fa-lightbulb mr-2"></i> <span>Neon Style</span></button>
                                            <button type=button data-style=cyberpunk class=option-btn-karikatur><i
