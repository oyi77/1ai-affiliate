                    <div id=content-ab-testing class="main-content-panel hidden">
                        <div class="container mx-auto max-w-7xl">
                            <header class="text-center mb-10">
                                <div class="inline-flex items-center gap-3 mb-4">
                                    <div class="w-16 h-16 rounded-2xl flex items-center justify-center shadow-lg"
                                        style="background:linear-gradient(135deg,#3b82f6 0,#8b5cf6 100%)"><i
                                            class="fas fa-chart-line text-white text-3xl"></i></div>
                                    <div class="flex flex-col items-start">
                                        <h1 class="text-4xl md:text-5xl font-bold text-transparent bg-clip-text"
                                            style="background:linear-gradient(135deg,#3b82f6 0,#8b5cf6 100%)">AI A/B
                                            Testing Recommender</h1><span
                                            class="text-xs font-semibold px-3 py-1 rounded-full mt-1 text-white"
                                            style="background:linear-gradient(135deg,#3b82f6 0,#8b5cf6 100%)">🎯 Predict
                                            Before You Post</span>
                                    </div>
                                </div>
                                <p class="text-lg text-gray-600 max-w-3xl mx-auto">Upload 2-4 content variants dan AI
                                    akan memprediksi mana yang paling berpotensi viral! Dapatkan score, insight, dan
                                    rekomendasi sebelum posting.</p>
                            </header>
                            <div class="flex flex-col lg:flex-row gap-8">
                                <div class="w-full lg:w-5/12 flex-shrink-0">
                                    <div class="card p-6 sticky top-6">
                                        <form id=abtest-form class="flex flex-col gap-6">
                                            <div>
                                                <div class="flex items-center gap-3 mb-4">
                                                    <div class="flex items-center justify-center w-8 h-8 rounded-full text-white font-bold text-sm shadow-lg"
                                                        style=background:linear-gradient(135deg,#3b82f6,#8b5cf6)>1</div>
                                                    <h3 class="text-lg font-bold text-gray-800">Upload Content Variants
                                                        *</h3>
                                                </div>
                                                <div class=space-y-3>
                                                    <div class=upload-box-abtest id=abtest-upload-a><input type=file
                                                            id=abtest-variant-a
                                                            accept="image/png, image/jpeg, image/webp, image/heic, .heic"
                                                            class=hidden> <label for=abtest-variant-a
                                                            class="cursor-pointer flex flex-col items-center justify-center h-full"><i
                                                                class="fas fa-image text-4xl mb-2 opacity-50"></i> <span
                                                                class="text-sm font-semibold">Variant A *</span> <span
                                                                class="text-xs opacity-75 mt-1">Click to
                                                                upload</span></label>
                                                        <div id=abtest-preview-a
                                                            class="hidden absolute inset-0 rounded-xl overflow-hidden">
                                                            <img src="" alt="Variant A"
                                                                class="w-full h-full object-cover"> <button type=button
                                                                class=abtest-remove-btn data-variant=a><i
                                                                    class="fas fa-times"></i></button>
                                                        </div>
                                                    </div>
                                                    <div class=upload-box-abtest id=abtest-upload-b><input type=file
                                                            id=abtest-variant-b
                                                            accept="image/png, image/jpeg, image/webp, image/heic, .heic"
                                                            class=hidden> <label for=abtest-variant-b
                                                            class="cursor-pointer flex flex-col items-center justify-center h-full"><i
                                                                class="fas fa-image text-4xl mb-2 opacity-50"></i> <span
                                                                class="text-sm font-semibold">Variant B *</span> <span
                                                                class="text-xs opacity-75 mt-1">Click to
                                                                upload</span></label>
                                                        <div id=abtest-preview-b
                                                            class="hidden absolute inset-0 rounded-xl overflow-hidden">
                                                            <img src="" alt="Variant B"
                                                                class="w-full h-full object-cover"> <button type=button
                                                                class=abtest-remove-btn data-variant=b><i
                                                                    class="fas fa-times"></i></button>
                                                        </div>
                                                    </div>
                                                    <div class=upload-box-abtest id=abtest-upload-c><input type=file
                                                            id=abtest-variant-c
                                                            accept="image/png, image/jpeg, image/webp, image/heic, .heic"
                                                            class=hidden> <label for=abtest-variant-c
                                                            class="cursor-pointer flex flex-col items-center justify-center h-full"><i
                                                                class="fas fa-image text-4xl mb-2 opacity-50"></i> <span
                                                                class="text-sm font-semibold">Variant C
                                                                (Optional)</span> <span
                                                                class="text-xs opacity-75 mt-1">Click to
                                                                upload</span></label>
                                                        <div id=abtest-preview-c
                                                            class="hidden absolute inset-0 rounded-xl overflow-hidden">
                                                            <img src="" alt="Variant C"
                                                                class="w-full h-full object-cover"> <button type=button
                                                                class=abtest-remove-btn data-variant=c><i
