                                            </div>
                                            <h3 class="text-lg font-bold text-gray-800">Upload Gambar</h3>
                                        </div><label for=analyzer-image-upload
                                            class="upload-box-analyzer block cursor-pointer text-center py-6 px-4 border-2 border-dashed rounded-xl transition-all duration-300 hover:scale-[1.02]"
                                            style="border-color:#06b6d4;background:linear-gradient(135deg,#ecfeff 0,#cffafe 100%)">
                                            <div class="flex flex-col items-center gap-2"><i
                                                    class="fas fa-cloud-upload-alt text-4xl" style=color:#06b6d4></i>
                                                <span class=font-semibold style=color:#0e7490>Klik untuk upload
                                                    gambar</span> <span class="text-xs text-gray-500">PNG, JPG, WEBP,
                                                    HEIC (max 10MB)</span>
                                            </div><input type=file id=analyzer-image-upload class=hidden
                                                accept="image/png, image/jpeg, image/webp, image/heic, .heic">
                                        </label>
                                        <div id=analyzer-image-preview-container class="mt-3 hidden"><img
                                                id=analyzer-image-preview src="" alt=Preview
                                                class="w-full rounded-lg shadow-lg max-h-64 object-cover border-2"
                                                style=border-color:#06b6d4> <button id=analyzer-remove-image
