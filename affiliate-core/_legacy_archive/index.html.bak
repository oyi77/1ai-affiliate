                                                    <div class="flex items-center justify-center w-8 h-8 rounded-full text-white font-bold text-sm shadow-lg"
                                                        style=background:linear-gradient(135deg,#10b981,#059669)>4</div>
                                                    <h3 class="text-lg font-bold text-gray-800">Content Mix</h3>
                                                </div>
                                                <div id=calendar-content-types class="grid grid-cols-2 gap-2 text-sm">
                                                    <button type=button data-value=Educational
                                                        class="checkbox-btn-calendar active"><i
                                                            class="fas fa-check mr-1"></i> Educational</button> <button
                                                        type=button data-value=Entertainment
                                                        class="checkbox-btn-calendar active"><i
                                                            class="fas fa-check mr-1"></i> Entertainment</button>
                                                    <button type=button data-value=Promotional
                                                        class="checkbox-btn-calendar active"><i
                                                            class="fas fa-check mr-1"></i> Promotional</button> <button
                                                        type=button data-value=Behind-the-Scenes
                                                        class=checkbox-btn-calendar><i
                                                            class="fas fa-check hidden mr-1"></i> BTS</button> <button
                                                        type=button data-value=User-Generated
                                                        class=checkbox-btn-calendar><i
                                                            class="fas fa-check hidden mr-1"></i> UGC</button> <button
