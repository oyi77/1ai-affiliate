                                                    style=color:#ec4899></i> <span>Semua Umur</span></div>
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#ec4899></i> <span>20 Tema</span></div>
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#ec4899></i> <span>Hasil Profesional</span></div>
