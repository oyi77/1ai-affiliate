                                            <h3 class="text-lg font-bold text-gray-800">Bahasa Output</h3>
                                        </div>
                                        <div id=analyzer-language class="grid grid-cols-2 gap-3"><button type=button
                                                data-value=id class="option-btn-analyzer selected"><i
                                                    class="fas fa-flag"></i> <span class=text-sm>Bahasa
                                                    Indonesia</span></button> <button type=button data-value=en
                                                class=option-btn-analyzer><i class="fas fa-globe"></i> <span
