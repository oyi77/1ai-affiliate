                                                <span>Anime/Manga</span></button> <button type=button data-style=cartoon
                                                class=option-btn-karikatur><i class="fas fa-laugh-squint mr-2"></i>
                                                <span>Cartoon Western</span></button> <button type=button
                                                data-style=pixar class=option-btn-karikatur><i
                                                    class="fas fa-cube mr-2"></i> <span>Pixar 3D</span></button> <button
                                                type=button data-style=disney class=option-btn-karikatur><i
                                                    class="fas fa-crown mr-2"></i> <span>Disney Style</span></button>
                                            <button type=button data-style=ghibli class=option-btn-karikatur><i
                                                    class="fas fa-wind mr-2"></i> <span>Studio Ghibli</span></button>
                                            <button type=button data-style=comic class=option-btn-karikatur><i
                                                    class="fas fa-book mr-2"></i> <span>Comic Book</span></button>
                                            <button type=button data-style=marvel class=option-btn-karikatur><i
                                                    class="fas fa-mask mr-2"></i> <span>Marvel Style</span></button>
                                            <button type=button data-style=chibi class=option-btn-karikatur><i
                                                    class="fas fa-baby mr-2"></i> <span>Chibi/Cute</span></button>
                                            <button type=button data-style=watercolor class=option-btn-karikatur><i
                                                    class="fas fa-paintbrush mr-2"></i> <span>Watercolor</span></button>
                                            <button type=button data-style=oilpainting class=option-btn-karikatur><i
                                                    class="fas fa-palette mr-2"></i> <span>Oil Painting</span></button>
                                            <button type=button data-style=sketch class=option-btn-karikatur><i
                                                    class="fas fa-pencil mr-2"></i> <span>Sketch</span></button> <button
                                                type=button data-style=lineart class=option-btn-karikatur><i
                                                    class="fas fa-pen mr-2"></i> <span>Line Art</span></button> <button
                                                type=button data-style=popart class=option-btn-karikatur><i
                                                    class="fas fa-fire mr-2"></i> <span>Pop Art</span></button> <button
                                                type=button data-style=graffiti class=option-btn-karikatur><i
                                                    class="fas fa-spray-can mr-2"></i> <span>Graffiti</span></button>
                                            <button type=button data-style=digital class=option-btn-karikatur><i
