                                                    </div>
                                                    <div
                                                        class="absolute top-0 left-0 animate-spin rounded-full h-16 w-16 border-t-4 border-cyan-600">
                                                    </div>
                                                </div>
                                                <p class="text-xl font-semibold mb-2" style=color:#0e7490>Menganalisis
                                                    gambar...</p>
                                                <p id=analyzer-loading-text class="text-gray-600 text-center">Memproses
                                                    detail gambar...</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div id=analyzer-error-message class="hidden mb-6">
                                        <div class="bg-red-50 border-2 border-red-200 rounded-xl p-6">
                                            <div class="flex items-start gap-3"><i
                                                    class="fas fa-exclamation-circle text-red-500 text-2xl mt-1"></i>
                                                <div class=flex-1>
                                                    <h4 class="font-bold text-red-700 mb-1">Terjadi Kesalahan</h4>
                                                    <p class="text-red-600 text-sm"></p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id=analyzer-results class=hidden>
                                        <div class="bg-white rounded-2xl shadow-xl p-6 border-2"
                                            style=border-color:#06b6d4>
                                            <div class="flex items-center justify-between mb-4">
                                                <h3 class="text-2xl font-bold flex items-center gap-2"
                                                    style=color:#0e7490><i class="fas fa-file-alt"></i> Prompt AI</h3>
                                                <button id=analyzer-copy-btn
                                                    class="bg-gradient-to-r from-cyan-500 to-cyan-600 hover:from-cyan-600 hover:to-cyan-700 text-white px-4 py-2 rounded-lg font-semibold shadow-md transition-all duration-200 hover:scale-105 active:scale-95 flex items-center gap-2"
                                                    style=-webkit-tap-highlight-color:transparent;touch-action:manipulation><i
                                                        class="fas fa-copy pointer-events-none"></i> <span
                                                        class="hidden sm:inline pointer-events-none">Copy</span></button>
                                            </div>
