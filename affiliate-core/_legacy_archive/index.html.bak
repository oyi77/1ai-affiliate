                                                    <div class="flex items-center justify-center w-8 h-8 rounded-full text-white font-bold text-sm shadow-lg"
                                                        style=background:linear-gradient(135deg,#10b981,#059669)>5</div>
                                                    <h3 class="text-lg font-bold text-gray-800">Brand Tone *</h3>
                                                </div>
                                                <div id=calendar-tone-options
                                                    class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm"><button
                                                        type=button data-value=Professional class=option-btn-calendar>👔
                                                        Professional</button> <button type=button
                                                        data-value="Casual & Friendly"
                                                        class="option-btn-calendar selected">😊 Casual</button> <button
                                                        type=button data-value="Fun & Playful"
                                                        class=option-btn-calendar>🎉 Playful</button> <button
                                                        type=button data-value=Inspirational class=option-btn-calendar>✨
                                                        Inspirational</button> <button type=button
                                                        data-value=Educational class=option-btn-calendar>📚
                                                        Educational</button> <button type=button data-value=Motivational
                                                        class=option-btn-calendar>💪 Motivational</button></div>
                                            </div><button type=submit id=calendar-generate-btn
                                                class="w-full py-4 px-6 rounded-xl font-bold text-lg text-white shadow-lg transition-all duration-300"
                                                style="background:linear-gradient(135deg,#10b981 0,#059669 100%)"
                                                disabled=disabled><i class="fas fa-calendar-check mr-2"></i>
                                                <span>Generate 30-Day Calendar</span></button>
                                            <p class="text-xs text-center text-gray-500">⏱️ Proses ~20-30 detik</p>
                                        </form>
                                    </div>
                                </div>
                                <div class="w-full lg:w-7/12 flex-1">
                                    <div class="card p-6">
                                        <div id=calendar-controls class="hidden mb-6">
                                            <div class="flex flex-col sm:flex-row gap-3 justify-between items-center">
                                                <div class="flex gap-2"><button type=button data-view=calendar
