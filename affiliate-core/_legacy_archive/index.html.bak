                                        class="w-14 h-14 rounded-2xl flex items-center justify-center shadow-lg bg-gradient-to-br from-teal-500 to-lime-500">
                                        <i class="fas fa-tshirt text-white text-2xl"></i>
                                    </div>
                                    <div class="flex flex-col items-start">
                                        <h1
                                            class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-teal-600 to-lime-600 bg-clip-text text-transparent">
                                            Virtual Try-On Pro</h1><span
                                            class="text-xs font-semibold px-3 py-1 rounded-full mt-1 bg-gradient-to-r from-teal-500 to-lime-500 text-white">✨
                                            AI Powered</span>
                                    </div>
                                </div>
                                <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">Coba
                                    produk fashion secara virtual dengan AI. Pilih angle dan dapatkan hasil profesional!
                                </p>
                            </header>
                            <div class="flex flex-col lg:flex-row gap-8 w-full">
                                <div class="w-full lg:w-5/12 flex-shrink-0">
                                    <div
                                        class="card p-8 sticky top-6 shadow-xl rounded-2xl border border-teal-100 bg-gradient-to-b from-white to-gray-50">
                                        <div class="flex flex-col gap-6">
                                            <div>
                                                <div class="flex items-center gap-3 mb-4">
                                                    <div
                                                        class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white shadow-md bg-gradient-to-br from-teal-500 to-lime-500">
                                                        1</div>
                                                    <h3 class="text-lg font-bold text-gray-800">Unggah Foto Produk</h3>
                                                </div>
                                                <div id=tryon-product-upload-box
                                                    class="upload-box w-full h-48 rounded-lg flex items-center justify-center cursor-pointer relative overflow-hidden border-2 border-dashed border-gray-300 hover:border-teal-500 transition-all bg-gradient-to-br from-gray-50 to-gray-100">
