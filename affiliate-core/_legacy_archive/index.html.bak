                                                    <h3 class="text-lg font-bold text-gray-800">Upload Referensi Mascot
                                                        *</h3>
                                                </div><label for=mascot-ref-input id=mascot-ref-upload-box
                                                    class="upload-box-mascot-ref w-full h-56 rounded-xl flex items-center justify-center cursor-pointer relative overflow-hidden border-2 border-dashed border-gray-300">
