                                        class="fas fa-image text-white text-3xl"></i></div>
                                <div class="flex flex-col items-start">
                                    <h1 class="text-4xl md:text-5xl font-bold text-transparent bg-clip-text"
                                        style="background:linear-gradient(135deg,#8b5cf6 0,#ec4899 100%)">Professional
                                        Poster Generator</h1><span
                                        class="text-xs font-semibold px-3 py-1 rounded-full mt-1 text-white"
                                        style="background:linear-gradient(135deg,#8b5cf6 0,#ec4899 100%)">🎨 AI-Powered
                                        Design</span>
                                </div>
                            </div>
                            <p class="text-lg text-gray-600 max-w-3xl mx-auto">Buat poster profesional untuk berbagai
                                kebutuhan dalam hitungan detik! Event, promosi, social media, dan banyak lagi dengan AI.
                            </p>
                        </header>
                        <div class="flex flex-col lg:flex-row gap-8">
                            <div class="w-full lg:w-5/12 flex-shrink-0">
                                <div class="card p-6 sticky top-6">
