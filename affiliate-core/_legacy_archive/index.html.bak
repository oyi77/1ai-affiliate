                                            class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-green-500 focus:ring-2 focus:ring-green-200 transition-all"
                                            placeholder="Contoh: Milenial urban 25-35 tahun, kelas menengah"></textarea>
