                                                    </div>
                                                </div>
                                                <p class="text-xl font-semibold mb-2" style=color:#78350f>Membuat desain
                                                    packaging...</p>
                                                <p id=packaging-loading-text class="text-gray-600 text-center">Merancang
                                                    kemasan profesional...</p>
                                                <div class="w-full max-w-md mt-6">
                                                    <div class="bg-gray-200 rounded-full h-3 overflow-hidden">
                                                        <div id=packaging-progress-bar
                                                            class="h-full rounded-full transition-all duration-500"
                                                            style="background:linear-gradient(135deg,#92400e 0,#78350f 100%);width:0%">
                                                        </div>
                                                    </div>
                                                    <p id=packaging-progress-text
                                                        class="text-sm text-center mt-2 font-medium"
                                                        style=color:#78350f>0/6 selesai</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id=packaging-error-message class="hidden mb-6">
                                        <div class="bg-red-50 border-2 border-red-200 rounded-xl p-6">
                                            <div class="flex items-start gap-3"><i
                                                    class="fas fa-exclamation-circle text-red-500 text-2xl mt-1"></i>
                                                <div class=flex-1>
                                                    <h4 class="font-bold text-red-700 mb-1">Terjadi Kesalahan</h4>
                                                    <p class="text-red-600 text-sm"></p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id=packaging-results-header
                                        class="hidden flex items-center justify-between mb-4 bg-gradient-to-r from-amber-50 to-yellow-50 p-4 rounded-xl border-2"
                                        style=border-color:#92400e>
                                        <h3 class="text-2xl font-bold" style=color:#78350f><i
                                                class="fas fa-check-circle mr-2" style=color:#92400e></i> <span
                                                id=packaging-results-count>6</span> Desain Packaging</h3><button
                                            id=packaging-download-all-btn
                                            class="bg-gradient-to-r from-amber-600 to-amber-700 hover:from-amber-700 hover:to-amber-800 text-white px-6 py-2 rounded-full font-semibold shadow-lg transition transform hover:scale-105 flex items-center gap-2"><i
                                                class="fas fa-download"></i> <span class="hidden sm:inline">Download
                                                Semua</span></button>
                                    </div>
                                    <div id=packaging-results-grid class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
                                    <div id=packaging-empty-state
                                        class="bg-white rounded-2xl shadow-lg p-12 text-center border-2 border-dashed"
                                        style=border-color:#92400e><i class="fas fa-box text-6xl mb-4"
                                            style=color:#92400e></i>
                                        <h3 class="text-2xl font-bold mb-3" style=color:#78350f>Siap Membuat Desain
                                            Packaging</h3>
                                        <p class="text-gray-600 mb-6 max-w-md mx-auto">Upload foto produk, pilih jenis
                                            kemasan dan style desain, lalu klik generate untuk membuat packaging design
                                            profesional!</p>
                                        <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-500">
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#92400e></i> <span>6 Jenis Kemasan</span></div>
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#92400e></i> <span>6 Style Desain</span></div>
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#92400e></i> <span>Print-Ready</span></div>
                                        </div>
                                    </div>
                                </main>
                            </div>
                        </div>
                    </div>
                    <div id=content-before-after class="main-content-panel hidden">
                        <div class="container mx-auto max-w-7xl">
                            <header class="text-center mb-8">
                                <h1 class="text-4xl md:text-5xl font-bold mb-3"><i class="fas fa-magic mr-3"
                                        style=color:#7c3aed></i>Before-After Generator</h1>
                                <p class="text-lg text-gray-600">Transform foto atau buat before-after scene untuk video
                                    content & presentation!</p>
                            </header>
                            <div class="flex justify-center mb-8">
                                <div class=mode-toggle-before-after><button id=ba-mode-upload class=active><i
                                            class="fas fa-image mr-2"></i>Upload & Transform</button> <button
                                        id=ba-mode-text><i class="fas fa-keyboard mr-2"></i>Text to Image</button></div>
                            </div>
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                                <aside
                                    class="bg-white rounded-2xl shadow-xl p-6 border-2 border-transparent hover:border-purple-200 transition-all duration-300">
                                    <h2 class="text-2xl font-bold mb-6 flex items-center gap-2" style=color:#6d28d9><i
                                            class="fas fa-sliders-h"></i> Pengaturan</h2>
                                    <div id=ba-upload-mode-content>
                                        <div class=mb-6>
                                            <div class="flex items-center gap-3 mb-4">
                                                <div class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white shadow-md"
                                                    style="background:linear-gradient(135deg,#7c3aed 0,#6d28d9 100%)">1
                                                </div>
                                                <h3 class="text-lg font-bold text-gray-800">Upload Foto "Before"</h3>
                                            </div><label for=ba-before-upload
                                                class="upload-box-before-after block cursor-pointer text-center py-6 px-4 border-2 border-dashed rounded-xl transition-all duration-300 hover:scale-[1.02]"
                                                style="border-color:#7c3aed;background:linear-gradient(135deg,#f5f3ff 0,#ede9fe 100%)">
                                                <div class="flex flex-col items-center gap-2"><i
                                                        class="fas fa-cloud-upload-alt text-4xl"
                                                        style=color:#7c3aed></i> <span class=font-semibold
                                                        style=color:#6d28d9>Upload foto "before"</span> <span
                                                        class="text-xs text-gray-500">PNG, JPG, WEBP, HEIC</span></div>
                                                <input type=file id=ba-before-upload class=hidden
                                                    accept="image/png, image/jpeg, image/webp, image/heic, .heic">
                                            </label>
                                            <div id=ba-before-preview-container class="mt-3 hidden"><img
                                                    id=ba-before-preview src="" alt="Before Preview"
                                                    class="w-full rounded-lg shadow-lg max-h-64 object-cover border-2"
                                                    style=border-color:#7c3aed> <button id=ba-remove-before
                                                    class="mt-2 w-full bg-red-600 hover:bg-red-700 text-white text-sm py-2 px-3 rounded-lg transition-all"><i
                                                        class="fas fa-times mr-1"></i> Hapus Foto</button></div>
                                        </div>
                                        <div class=mb-6>
                                            <div class="flex items-center gap-3 mb-4">
                                                <div class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white shadow-md"
                                                    style="background:linear-gradient(135deg,#7c3aed 0,#6d28d9 100%)">2
                                                </div>
                                                <h3 class="text-lg font-bold text-gray-800">Prompt Transformasi</h3>
                                            </div><textarea id=ba-transform-prompt rows=4
                                                class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-purple-500 focus:outline-none transition-all resize-none"
                                                placeholder="Contoh: Ubah lapangan ini menjadi ada bangunan hotel mewah 5 lantai dengan kolam renang"></textarea>
                                            <p class="text-xs text-gray-500 mt-2"><i class="fas fa-lightbulb mr-1"
                                                    style=color:#7c3aed></i> Jelaskan transformasi yang diinginkan
                                                secara detail</p>
                                        </div><button id=ba-generate-upload-btn disabled=disabled
                                            class="w-full bg-gradient-to-r from-purple-600 to-purple-700 hover:from-purple-700 hover:to-purple-800 text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 shadow-lg hover:shadow-2xl hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"><i
                                                class="fas fa-magic mr-2"></i> Generate After Image</button>
                                    </div>
                                    <div id=ba-text-mode-content class=hidden>
                                        <div class=mb-6>
                                            <div class="flex items-center gap-3 mb-4">
                                                <div class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white shadow-md"
                                                    style="background:linear-gradient(135deg,#7c3aed 0,#6d28d9 100%)">1
                                                </div>
                                                <h3 class="text-lg font-bold text-gray-800">Deskripsi Before-After</h3>
                                            </div><textarea id=ba-text-prompt rows=6
                                                class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-purple-500 focus:outline-none transition-all resize-none"
                                                placeholder="Contoh: Buat before after dari lapangan gersang kosong menjadi kompleks hotel mewah dengan gedung 5 lantai, taman hijau, dan kolam renang"></textarea>
                                            <p class="text-xs text-gray-500 mt-2"><i class="fas fa-lightbulb mr-1"
                                                    style=color:#7c3aed></i> Jelaskan kondisi "before" dan "after"
                                                secara lengkap</p>
                                        </div>
                                        <div class=mb-6>
                                            <div class="flex items-center gap-3 mb-4">
                                                <div class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white shadow-md"
                                                    style="background:linear-gradient(135deg,#7c3aed 0,#6d28d9 100%)">2
                                                </div>
                                                <h3 class="text-lg font-bold text-gray-800">Aspect Ratio</h3>
                                            </div>
                                            <div id=ba-ratio-options class="grid grid-cols-3 gap-3"><button type=button
                                                    data-ratio=1:1
                                                    class="px-3 py-2 border-2 border-gray-300 rounded-lg hover:border-purple-500 transition-all bg-white"><span
                                                        class=font-semibold>1:1</span></button> <button type=button
                                                    data-ratio=16:9
                                                    class="px-3 py-2 border-2 border-purple-500 rounded-lg bg-gradient-to-r from-purple-50 to-purple-100 font-bold"
                                                    style=color:#6d28d9><span>16:9</span></button> <button type=button
                                                    data-ratio=9:16
                                                    class="px-3 py-2 border-2 border-gray-300 rounded-lg hover:border-purple-500 transition-all bg-white"><span
                                                        class=font-semibold>9:16</span></button></div>
                                        </div><button id=ba-generate-text-btn disabled=disabled
                                            class="w-full bg-gradient-to-r from-purple-600 to-purple-700 hover:from-purple-700 hover:to-purple-800 text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 shadow-lg hover:shadow-2xl hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"><i
                                                class="fas fa-magic mr-2"></i> Generate Before & After Images</button>
                                    </div>
                                </aside>
                                <main>
                                    <div id=ba-loading class="hidden mb-6">
                                        <div class="bg-gradient-to-r from-purple-50 to-purple-100 rounded-2xl shadow-lg p-8 border-2"
                                            style=border-color:#7c3aed>
                                            <div class="flex flex-col items-center">
                                                <div class="relative mb-4">
                                                    <div
                                                        class="animate-spin rounded-full h-16 w-16 border-4 border-purple-200">
                                                    </div>
                                                    <div
                                                        class="absolute top-0 left-0 animate-spin rounded-full h-16 w-16 border-t-4 border-purple-700">
                                                    </div>
                                                </div>
                                                <p class="text-xl font-semibold mb-2" style=color:#6d28d9>Membuat
                                                    transformasi...</p>
                                                <p id=ba-loading-text class="text-gray-600 text-center">Menganalisis dan
                                                    mentransformasi gambar...</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div id=ba-error-message class="hidden mb-6">
                                        <div class="bg-red-50 border-2 border-red-200 rounded-xl p-6">
                                            <div class="flex items-start gap-3"><i
                                                    class="fas fa-exclamation-circle text-red-500 text-2xl mt-1"></i>
                                                <div class=flex-1>
                                                    <h4 class="font-bold text-red-700 mb-1">Terjadi Kesalahan</h4>
                                                    <p class="text-red-600 text-sm"></p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id=ba-results class=hidden>
                                        <div class="bg-white rounded-2xl shadow-xl p-6 border-2"
                                            style=border-color:#7c3aed>
                                            <h3 class="text-2xl font-bold mb-4 flex items-center gap-2"
                                                style=color:#6d28d9><i class="fas fa-check-circle"></i> <span
                                                    id=ba-results-title>Hasil Transformasi</span></h3>
                                            <div id=ba-results-grid class="grid grid-cols-1 gap-6"></div>
                                            <div class="mt-4 flex items-center gap-2 text-sm text-gray-500"><i
                                                    class="fas fa-info-circle" style=color:#7c3aed></i> <span>Download
                                                    foto dan gunakan di Google Flow untuk membuat video
                                                    transition</span></div>
                                        </div>
                                    </div>
                                    <div id=ba-empty-state
                                        class="bg-white rounded-2xl shadow-lg p-12 text-center border-2 border-dashed"
                                        style=border-color:#7c3aed><i class="fas fa-magic text-6xl mb-4"
                                            style=color:#7c3aed></i>
                                        <h3 class="text-2xl font-bold mb-3" style=color:#6d28d9>Siap Membuat
                                            Before-After</h3>
                                        <p class="text-gray-600 mb-6 max-w-md mx-auto">Pilih mode di atas, lalu upload
                                            foto atau ketik prompt untuk generate before-after images!</p>
                                        <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-500">
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#7c3aed></i> <span>2 Mode Generation</span></div>
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#7c3aed></i> <span>High Quality Output</span></div>
                                            <div class="flex items-center gap-2"><i class="fas fa-check-circle"
                                                    style=color:#7c3aed></i> <span>Google Flow Ready</span></div>
                                        </div>
                                    </div>
                                </main>
                            </div>
                        </div>
                    </div>
                    <div id=content-desain-rumah class="main-content-panel hidden">
                        <div class="container mx-auto max-w-7xl">
                            <header class="text-center mb-8">
                                <h1 class="text-4xl md:text-5xl font-bold mb-3"><i class="fas fa-home mr-3"></i>ReDesain
                                    Rumah</h1>
                                <p class="text-lg text-gray-600">Desain ulang ruangan interior atau renovasi eksterior
                                    rumah Anda dengan AI</p>
                            </header>
                            <div
                                class="mb-8 max-w-md mx-auto p-1.5 bg-slate-100 rounded-xl flex items-center justify-center gap-2 shadow-inner">
                                <button id=dr-tab-interior
                                    class="option-btn-desain selected w-full text-center">Interior</button> <button
                                    id=dr-tab-eksterior class="option-btn-desain w-full text-center">Eksterior <span
                                        class="bg-red-500 text-white text-xs font-bold px-1.5 py-0.5 rounded-full ml-1">New</span></button>
                            </div>
                            <div id=dr-content-interior>
                                <div class="mb-6 flex items-center gap-3 p-3 sm:p-4 rounded-xl border text-left"
                                    style="background:linear-gradient(to right,#e0f2fe,#e0f2fe);border-color:#0ea5e9;color:#0284c7">
                                    <div class=flex-shrink-0><i class="fas fa-info-circle" style=color:#0ea5e9></i>
                                    </div>
                                    <p class="text-sm md:text-base">Unggah foto ruangan, tambahkan furnitur, pilih gaya,
                                        dan biarkan AI mendesain ulang ruangan Anda secara ajaib.</p>
                                </div>
                                <div class="mt-8 flex flex-col lg:flex-row gap-8 w-full">
                                    <div class="w-full lg:w-5/12 flex-shrink-0">
                                        <div class="card p-4 sm:p-6 sticky top-6">
                                            <div class="flex flex-col gap-5">
                                                <div>
                                                    <h3 class="text-base font-semibold mb-3 text-gray-800">1. Unggah
