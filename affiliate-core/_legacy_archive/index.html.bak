                                                    class=text-sm>General</span></button> <button type=button
                                                data-value=photography class=option-btn-analyzer><i
                                                    class="fas fa-camera"></i> <span
                                                    class=text-sm>Photography</span></button> <button type=button
                                                data-value=art class=option-btn-analyzer><i class="fas fa-palette"></i>
