                                                    <div class="flex items-center justify-center w-8 h-8 rounded-full text-white font-bold text-sm shadow-lg"
                                                        style=background:linear-gradient(135deg,#10b981,#059669)>2</div>
                                                    <h3 class="text-lg font-bold text-gray-800">Target Platforms *</h3>
                                                </div>
                                                <div id=calendar-platform-options
                                                    class="grid grid-cols-2 sm:grid-cols-3 gap-3"><button type=button
                                                        data-value=Instagram class=checkbox-btn-calendar><i
                                                            class="fas fa-check hidden mr-1"></i> Instagram</button>
                                                    <button type=button data-value=TikTok class=checkbox-btn-calendar><i
                                                            class="fas fa-check hidden mr-1"></i> TikTok</button>
